#
# Template for Package Config File
#
# This template generates the ${PROJECT_NAME}Config.cmake file.

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Include the exported targets
include("${CMAKE_CURRENT_LIST_DIR}/${PROJECT_NAME}Targets.cmake")

# Check all required components
check_required_components(${PROJECT_NAME})

# Provide version information
set(${PROJECT_NAME}_VERSION "${PROJECT_VERSION}")

# Provide imported targets
get_target_property(${PROJECT_NAME}_INCLUDE_DIRS ${PROJECT_NAME} INCLUDE_DIRECTORIES)
get_target_property(${PROJECT_NAME}_LINK_LIBRARIES ${PROJECT_NAME} IMPORTED_LINK_INTERFACE_LIBRARIES)

# Provide additional information
set(${PROJECT_NAME}_FOUND TRUE)
set(${PROJECT_NAME}_INCLUDE_DIR "${CMAKE_CURRENT_LIST_DIR}")
set(${PROJECT_NAME}_VERSION "${PROJECT_VERSION}")

check_required_components(${PROJECT_NAME})