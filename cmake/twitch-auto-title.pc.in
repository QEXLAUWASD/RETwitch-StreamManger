#
# Template for pkg-config file
#
# This template generates the ${PROJECT_NAME}.pc file for pkg-config.

prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: @PROJECT_NAME@
Description: @PROJECT_DESCRIPTION@
URL: @PROJECT_HOMEPAGE_URL@
Version: @PROJECT_VERSION@

Requires:
libobs
@if(ENABLE_FRONTEND_API)
obs-frontend-api
@endif
@if(ENABLE_QT)
Qt6Core
Qt6Widgets
Qt6Network
@endif

Libs:
  -L${libdir} -l@PROJECT_NAME@
Cflags:
  -I${includedir}/@PROJECT_NAME@